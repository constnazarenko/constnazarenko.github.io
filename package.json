{
  "name": "cv-page",
  "version": "2.0.0",
  "description": "Definitely a huge overkill for a static cv.",
  "repository": {
    "type": "git",
    "url": "git@github.com:constnazarenko/constnazarenko.github.io.git"
  },
  "keywords": [
    "ts",
    "cv"
  ],
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "src/*",
    "dist/*"
  ],
  "author": {
    "name": "Kostiantyn Nazarenko",
    "email": "const@nazarenko.es"
  },
  "homepage": "https://constnazarenko.github.io/",
  "private": true,
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "6.5.1",
    "@fortawesome/free-brands-svg-icons": "6.5.1",
    "@fortawesome/free-regular-svg-icons": "6.5.1",
    "@fortawesome/free-solid-svg-icons": "6.5.1",
    "@fortawesome/react-fontawesome": "0.2.0",
    "classnames": "2.5.1",
    "dotenv": "16.4.5",
    "react-router-dom": "6.22.3",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@svgr/webpack": "8.1.0",
    "@trivago/prettier-plugin-sort-imports": "4.3.0",
    "@types/react": "18.2.64",
    "@types/react-dom": "18.2.21",
    "@typescript-eslint/eslint-plugin": "7.1.1",
    "@typescript-eslint/parser": "7.1.1",
    "autoprefixer": "10.4.18",
    "clean-webpack-plugin": "4.0.0",
    "copy-webpack-plugin": "12.0.2",
    "css-loader": "6.10.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "html-webpack-plugin": "5.6.0",
    "husky": "9.0.11",
    "lint-staged": "15.2.2",
    "mini-css-extract-plugin": "2.8.1",
    "npm-check": "6.0.1",
    "postcss": "8.4.35",
    "postcss-loader": "8.1.1",
    "postcss-preset-env": "9.5.0",
    "prettier": "3.2.5",
    "prettier-plugin-organize-imports": "3.2.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sass": "1.71.1",
    "sass-loader": "14.1.1",
    "source-map-explorer": "2.5.3",
    "source-map-loader": "5.0.0",
    "style-loader": "3.3.4",
    "stylelint": "16.2.1",
    "stylelint-config-prettier-scss": "1.0.0",
    "stylelint-config-standard-scss": "13.0.0",
    "stylelint-scss": "6.2.1",
    "tailwindcss": "3.4.1",
    "ts-loader": "9.5.1",
    "typescript": "5.4.2",
    "webpack": "5.90.3",
    "webpack-cli": "5.1.4",
    "webpack-dev-server": "5.0.2",
    "webpack-merge": "5.10.0"
  },
  "scripts": {
    "analyze": "source-map-explorer 'dist/*.js' --html bundle-analysis.html",
    "build": "webpack --config webpack.prod.js",
    "check-types": "tsc",
    "compile": "tsc -p .",
    "deploy": "gh-pages -d dist -b master --git git",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:css": "npx stylelint 'src/**/*.scss'",
    "lint:css:fix": "npx stylelint 'src/**/*.scss' --fix",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "posttest": "npm run check-types",
    "predeploy": "npm run build",
    "prepare": "npm update && npm run compile && husky install",
    "pretest": "npm run compile",
    "prettier": "prettier --check src/ ./package.json ./README.md",
    "prettier:fix": "prettier --write --ignore-unknown src/ ./package.json ./README.md",
    "start": "webpack serve --config webpack.dev.js",
    "test": "npm run compile",
    "update-interactive": "npm-check --update --save-exact"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,scss,md}": "prettier --write",
    "*.{css,scss}": "stylelint --fix"
  },
  "engines": {
    "npm": ">=10",
    "node": ">=20"
  }
}
